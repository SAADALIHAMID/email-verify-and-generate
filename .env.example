# Application Environment
APP_ENV=dev
LOG_LEVEL=info

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/emailverify

# Redis
REDIS_URL=redis://localhost:6379/0

# Caching
CACHE_TTL_SECONDS=604800

# SMTP Settings
SMTP_CONNECT_TIMEOUT=10
SMTP_OP_TIMEOUT=15
FAKE_LOCAL_DOMAIN=verify.example.com

# DNS Settings
DNS_RESOLVE_TIMEOUT=5

# Concurrency & Rate Limiting
MAX_CONCURRENCY=100
RATE_LIMIT_PER_DOMAIN_PER_MIN=5

# Retry Settings (comma-separated seconds for backoff)
RETRY_BACKOFF_SECONDS=15,60,300

# Catch-all Detection
CATCH_ALL_RANDOM_LOCALPART_LEN=16

# Feature Toggles
ROLE_BASED_CHECK=true

# Disposable Domains Auto-Update
DISPOSABLE_AUTO_UPDATE_URL=https://raw.githubusercontent.com/disposable-email-domains/disposable-email-domains/master/disposable_email_blocklist.conf

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Worker Settings
WORKER_CONCURRENCY=4

# Streamlit Settings
STREAMLIT_PORT=8501